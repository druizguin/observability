{
  "Settings": {
    "serviceUrl": "http://localhost:5398",
    "rabbitServer": "rabbitmq", //rabbitmq
    "rabbitUser": "guest",
    "rabbitPassword": "guest"
  },
  "Observability": {
    "EnableMetrics": true,
    "EnableTracing": true,
    //"OtelUrl": null,
    "Metrics": {
      "Prefix": "unir",
      "Meters": [ "System.Net.Http", "System.Runtime" ],
      "WithConsoleExporter": false
    },
    "Tracing": {
      "WithConsoleExporter": false,
      "RedisUrl": "localhost:6379" //redis:6379
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Opentelemetry"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://otelcol:4317", //OTELCollector int
          //"Endpoint": "http://localhost:4317", //OTELCollector ext
          //"Endpoint": "http://localhost:18889", //Aspire Dashboard
          "ResourceAttributes": {
            "service.name": "des.arq.ratingvalidator.cli"
          }
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}