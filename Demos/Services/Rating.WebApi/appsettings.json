{
  "settings": {
    "serviceUrl": "http://localhost:5298",
    "rabbitServer": "localhost", //rabbitmq
    "rabbitUser": "guest",
    "rabbitPassword": "guest"
  },

  // [Demo V2] 1.1 Config: Configuración de observabilidadI
  "Observability": {
    "EnableMetrics": true,
    "EnableTracing": true,
    "Metrics": {
      "Prefix": "unir",
      "IncludeServiceName": true,
      "Meters": [
        "System.Net.Http",
        "System.Runtime"
      ],
      "WithConsoleExporter": false
    },
    "Tracing": {
      "WithConsoleExporter": false,
      "RedisUrl": "localhost:6379" //redis:6379
    }
  },

  // [Demo V2] 1.2 Config: Cambios Serilog
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Opentelemetry"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://otelcol:4317", //OTELCollector int
          //"Endpoint": "http://localhost:4317", //OTELCollector ext
          //"Endpoint": "http://localhost:18889", //Aspire Dashboard
          "ResourceAttributes": {
            "service.name": "des.arq.rating.api"
          }
        }
      }
    ]
  },


  "Logging": {
    "LogLevel": {
      "Default": "Warning", //Information
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PeriodicalBackgroundSettings": {
    "MinInterval": 15000,
    "MaxInterval": 60000
  }
}

