{
  "Settings": {
    "serviceUrl": "http://rating.webapi:5398",
    "MinInterval": "00:00:30",
    "MaxInterval": "00:01:00"
  },
  "Observability": {
    "EnableMetrics": true,
    "EnableTracing": true,
    "Metrics": {
      "Prefix": "unir",
      "ExportIntervalMilliseconds": 1000,
      "IncludeServiceName": true,
      "Meters": [
        "System.Net.Http",
        "System.Runtime"
      ],
      "WithConsoleExporter": false
    },
    "Tracing": {
      "WithConsoleExporter": false
    }
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Opentelemetry"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://otelcol:4317", //OTELCollector int
          //"Endpoint": "http://localhost:4317", //OTELCollector ext
          //"Endpoint": "http://localhost:18889", //Aspire Dashboard
          "ResourceAttributes": {
            "service.name": "des.cli.rating.cli"
          }
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}