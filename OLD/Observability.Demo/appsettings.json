{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },


  // [Demo V2] 1.1 Config: Configuración de observabilidad
  "Observability": {
    "EnableMetrics": true,
    "EnableTracing": true,
    "Metrics": {
      "Prefix": "biz",
      "IncludeServiceName": true,
      "Meters": [
        "System.Net.Http",
        "System.Runtime"
      ],
      "WithConsoleExporter": false
    },
    "Tracing": {
      "WithConsoleExporter": false,
      "RedisUrl": "localhost:6379" //redis:6379
    }
  },

  // [Demo V2] 1.2 Config: Cambios Serilog
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Opentelemetry"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "OpenTelemetry",
        "Args": {
          //"Endpoint": "http://otel-collector:4317", //OTELCollector int
          //"Endpoint": "http://localhost:4317", //OTELCollector ext
          "Endpoint": "http://localhost:18889", //Aspire Dashboard
          "ResourceAttributes": {
            "service.name": "des.arq.rating.api"
          }
        }
      }
    ]
  },

  "OpenTelemetrySettings": {
    "AppName": "ObservabilityObservabilityDemos",
    "ServiceName": "ObservabilityObservabilityDemoWebApi",
    "ServiceVersion": "0.1",
    "OtelCollectorUrl": "http://localhost:4317",
    "metrics": [
      "Microsoft.AspNetCore.Hosting",
      "Microsoft.AspNetCore.Server.Kestrel",
      "Microsoft.AspNetCore.Http.Connections",
      "Microsoft.AspNetCore.Routing",
      "Microsoft.AspNetCore.Diagnostics",
      "Microsoft.AspNetCore.RateLimiting",
      "System.Net.Http",
      "System.Net.NameResolution",
      "System.Runtime"
    ],
    "AllowedHosts": "*"
  }
}
